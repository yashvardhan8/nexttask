generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("Pending")
  createdAt   DateTime  @default(now())
  userId      String
  dueDate     DateTime?
  priority    String    @default("Medium")
}
